                                                        <Image Source="{DynamicResource AndroidRefreshDrawingImage}" VerticalAlignment="Bottom" HorizontalAlignment="Right"
                                                               Margin="0,0,-3,-3" Width="11">
                                                        </Image>
                                                    </Grid>
                                                </ui:SimpleStackPanel>
