                                            </ui:SimpleStackPanel>
                                        </Border>
                                    </Popup>
                                </Grid>
                                <ui:FontIcon x:Name="SymbolIconText" Glyph="{x:Static local:FluentIconGlyphs.TextEdit}"
                                               Foreground="{DynamicResource FloatBarForeground}"
                                               MouseDown="Border_MouseDown" MouseUp="SymbolIconText_MouseUp"
                                               ToolTipService.ToolTip="文本输入：点击画板添加文字 (Alt+T)"/>
                                <ui:FontIcon Glyph="{x:Static local:FluentIconGlyphs.Cancel}" Margin="0,0,0,0" Foreground="{DynamicResource FloatBarForeground}" MouseDown="Border_MouseDown" MouseUp="BtnExit_Click"
                                               ToolTipService.ToolTip="退出程序"/>
                            </ui:SimpleStackPanel>
                        </ui:SimpleStackPanel>
                    </ui:SimpleStackPanel>
                </Border>
            </ui:SimpleStackPanel>
        </Viewbox>
        <Grid Name="GridForFloatingBarDraging" Background="#01000000" Visibility="Collapsed"
              MouseMove="SymbolIconEmoji_MouseMove" MouseUp="SymbolIconEmoji_MouseUp"/>
