<Window x:Class="Ink_Anything.CloseDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Ink_Anything" xmlns:ui="http://schemas.inkore.net/lib/ui/wpf/modern"
        mc:Ignorable="d" Topmost="True" WindowStartupLocation="CenterScreen" ui:WindowHelper.UseModernWindowStyle="True"
        ResizeMode="NoResize" ui:ThemeManager.RequestedTheme="Light"
        Title="Ink Anything 画板" Height="180" Width="400" FontFamily="Microsoft YaHei UI">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition/>
            <RowDefinition Height="30"/>
            <RowDefinition Height="45"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="您希望如何处理 Ink Anything？" FontSize="15" VerticalAlignment="Center"/>

        <CheckBox Grid.Row="1" Name="CheckBoxRemember" Content="记住我的选择" FontSize="13" VerticalAlignment="Center"/>

        <ui:SimpleStackPanel Grid.Row="2" HorizontalAlignment="Right" VerticalAlignment="Bottom" Orientation="Horizontal" Spacing="10">
            <Button Content="退出程序" Width="100" FontFamily="Microsoft YaHei UI" Click="ButtonExit_Click"/>
            <Button Content="最小化到托盘" Width="120" FontFamily="Microsoft YaHei UI" Click="ButtonMinimize_Click"/>
        </ui:SimpleStackPanel>
    </Grid>
</Window>
